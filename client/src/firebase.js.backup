  });
  
  const followersRef = ref(database, `users/${followingId}/followers/${followerId}`);
  await set(followersRef, {
    followedAt: Date.now()
  });
};

// Unfollow a user
export const unfollowUser = async (followerId, followingId) => {
  const followingRef = ref(database, `users/${followerId}/following/${followingId}`);
  await set(followingRef, null);
  
  const followersRef = ref(database, `users/${followingId}/followers/${followerId}`);
