// Search users by username
export const searchUserByUsername = async (username) => {
  const usernamesRef = ref(database, 'usernames');
  const snapshot = await get(usernamesRef);
  
  if (snapshot.exists()) {
    const usernames = snapshot.val();
    for (const [userId, uname] of Object.entries(usernames)) {
      if (uname.toLowerCase() === username.toLowerCase()) {
        const profile = await getUserProfile(userId);
        return { userId, ...profile };
      }
    }
  }
  return null;
};

// ==================== COMMUNITY FEATURES ====================

// Get all community posts
export const getCommunityPosts = async () => {
  const postsRef = ref(database, 'community/posts');
  const snapshot = await get(postsRef);
  if (snapshot.exists()) {
    const posts = [];
    snapshot.forEach((child) => {
      posts.push({ id: child.key, ...child.val() });
    });
    // Sort by createdAt descending
    return posts.sort((a, b) => b.createdAt - a.createdAt);
  }
  return [];
};

// Create a new post
export const createPost = async (userId, username, postData) => {
  const postsRef = ref(database, 'community/posts');
  const newPostRef = push(postsRef);
  await set(newPostRef, {
    userId,
    username,
    content: postData.content || '',
    code: postData.code || '',
    language: postData.language || 'javascript',
    avatar: postData.avatar || '',
    likes: [],
    comments: [],
    views: 0,
    createdAt: Date.now()
  });
  return newPostRef.key;
};

// Like a post
export const likePost = async (postId, userId) => {
  const likesRef = ref(database, `community/posts/${postId}/likes`);
  const snapshot = await get(likesRef);
  let likes = snapshot.exists() ? snapshot.val() : [];
  
  if (likes.includes(userId)) {
    // Unlike
    likes = likes.filter(id => id !== userId);
  } else {
    // Like
    likes.push(userId);
  }
  
  await set(likesRef, likes);
};

// Comment on a post
export const commentOnPost = async (postId, userId, username, commentText) => {
  const commentsRef = ref(database, `community/posts/${postId}/comments`);
  const snapshot = await get(commentsRef);
  const comments = snapshot.exists() ? snapshot.val() : [];
  
  const userProfile = await getUserProfile(userId);
  
  comments.push({
    userId,
    username,
    avatar: userProfile?.photoURL || '',
    text: commentText,
    timestamp: Date.now()
  });
  
  await set(commentsRef, comments);
};

// Follow a user
export const followUser = async (followerId, followingId) => {
  const followingRef = ref(database, `users/${followerId}/following/${followingId}`);
