// Get trending posts (most likes + comments in last 7 days)
export const getTrendingPosts = async () => {
  const posts = await getCommunityPosts();
  const sevenDaysAgo = Date.now() - (7 * 24 * 60 * 60 * 1000);
  
  const recentPosts = posts.filter(post => post.createdAt > sevenDaysAgo);
  
  // Sort by engagement (likes + comments)
  return recentPosts.sort((a, b) => {
    const engagementA = (a.likes?.length || 0) + (a.comments?.length || 0);
    const engagementB = (b.likes?.length || 0) + (b.comments?.length || 0);
    return engagementB - engagementA;
  });
};

// Search users by username
export const searchUsers = async (query) => {
  const usernamesRef = ref(database, 'usernames');
  const snapshot = await get(usernamesRef);
  
  if (!snapshot.exists()) return [];
  
  const results = [];
  const usernames = snapshot.val();
  const lowerQuery = query.toLowerCase();
  
  for (const [userId, username] of Object.entries(usernames)) {
    if (username.toLowerCase().includes(lowerQuery)) {
      const profile = await getUserProfile(userId);
      if (profile) {
        // Get follower count
        const followersRef = ref(database, `users/${userId}/followers`);
        const followersSnapshot = await get(followersRef);
        const followers = followersSnapshot.exists() ? Object.keys(followersSnapshot.val()).length : 0;
        
        results.push({
          id: userId,
          username: profile.username,
          photoURL: profile.photoURL,
          followers
        });
      }
    }
  }
  
  return results;
};

// ==================== MESSENGER FEATURES ====================

// Get conversations for a user
export const getConversations = async (userId) => {
  const conversationsRef = ref(database, `conversations`);
  const snapshot = await get(conversationsRef);
  
  if (!snapshot.exists()) return [];
  
  const conversations = [];
  snapshot.forEach((child) => {
    const convo = child.val();
    // Check if user is participant
    if (convo.participants && convo.participants[userId]) {
      const otherUserId = Object.keys(convo.participants).find(id => id !== userId);
      const otherUser = convo.participants[otherUserId];
      
      conversations.push({
        id: child.key,
        otherUser: {
          id: otherUserId,
          username: otherUser.username,
          photoURL: otherUser.photoURL
        },
        lastMessage: convo.lastMessage || null,
        unreadCount: convo.unreadCount?.[userId] || 0
      });
    }
  });
  
  // Sort by last message timestamp
  return conversations.sort((a, b) => {
    const timeA = a.lastMessage?.timestamp || 0;
    const timeB = b.lastMessage?.timestamp || 0;
    return timeB - timeA;
  });
};

// Get messages in a conversation
export const getMessages = async (conversationId) => {
  const messagesRef = ref(database, `conversations/${conversationId}/messages`);
  const snapshot = await get(messagesRef);
  
  if (!snapshot.exists()) return [];
  
  const messages = [];
  snapshot.forEach((child) => {
    messages.push({ id: child.key, ...child.val() });
  });
  
  // Sort by timestamp ascending
  return messages.sort((a, b) => a.timestamp - b.timestamp);
};

// Send a message
export const sendMessage = async (conversationId, senderId, senderName, senderAvatar, text) => {
  const messageRef = push(ref(database, `conversations/${conversationId}/messages`));
  const timestamp = Date.now();
  
  await set(messageRef, {
    senderId,
    senderName,
    senderAvatar,
    text,
    timestamp,
    read: false
  });
  
  // Update last message
  const lastMessageRef = ref(database, `conversations/${conversationId}/lastMessage`);
  await set(lastMessageRef, {
    senderId,
    text,
    timestamp
  });
  
  // Increment unread count for other user
  const convoRef = ref(database, `conversations/${conversationId}/participants`);
  const snapshot = await get(convoRef);
  if (snapshot.exists()) {
    const participants = snapshot.val();
    const otherUserId = Object.keys(participants).find(id => id !== senderId);
    if (otherUserId) {
      const unreadRef = ref(database, `conversations/${conversationId}/unreadCount/${otherUserId}`);
      const unreadSnapshot = await get(unreadRef);
      const currentCount = unreadSnapshot.exists() ? unreadSnapshot.val() : 0;
      await set(unreadRef, currentCount + 1);
    }
  }
};

// Create a new conversation
export const createConversation = async (userId1, userId2, username1, username2, photoURL1, photoURL2) => {
  // Check if conversation already exists
  const conversationsRef = ref(database, 'conversations');
  const snapshot = await get(conversationsRef);
  
  if (snapshot.exists()) {
    // Find existing conversation
    let existingId = null;
    snapshot.forEach((child) => {
      const convo = child.val();
      if (convo.participants && 
          convo.participants[userId1] && 
          convo.participants[userId2]) {
        existingId = child.key;
      }
    });
    
    if (existingId) return existingId;
  }
  
  // Create new conversation
  const newConvoRef = push(conversationsRef);
  await set(newConvoRef, {
    participants: {
      [userId1]: {
        username: username1,
        photoURL: photoURL1
      },
      [userId2]: {
        username: username2,
        photoURL: photoURL2
      }
    },
    createdAt: Date.now(),
    unreadCount: {
      [userId1]: 0,
      [userId2]: 0
    }
  });
  
  return newConvoRef.key;
};

// Mark messages as read
export const markAsRead = async (conversationId, userId) => {
  const unreadRef = ref(database, `conversations/${conversationId}/unreadCount/${userId}`);
  await set(unreadRef, 0);
  
  // Mark all messages as read
  const messagesRef = ref(database, `conversations/${conversationId}/messages`);
  const snapshot = await get(messagesRef);
  
  if (snapshot.exists()) {
    snapshot.forEach((child) => {
      const msg = child.val();
      if (msg.senderId !== userId && !msg.read) {
        const readRef = ref(database, `conversations/${conversationId}/messages/${child.key}/read`);
        set(readRef, true);
      }
    });
  }
};

// Get online users
export const getOnlineUsers = async () => {
  const usersRef = ref(database, 'users');
  const snapshot = await get(usersRef);
  
  if (!snapshot.exists()) return [];
  
  const onlineUsers = [];
  snapshot.forEach((child) => {
    const status = child.val().status;
    if (status && status.online) {
      onlineUsers.push(child.key);
    }
  });
  
  return onlineUsers;
};
