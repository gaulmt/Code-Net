{
  "rules": {
    "otp_pending": {
      "$email": {
        ".read": true,
        ".write": true
      }
    },
    "usernames": {
      ".read": true,
      "$userId": {
        ".write": "auth != null && (auth.uid == $userId || !data.exists())"
      }
    },
    "users": {
      "$userId": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $userId",
        "profile": {
          ".read": "auth != null",
          ".write": "auth != null && auth.uid == $userId"
        },
        "projects": {
          ".read": "auth != null && auth.uid == $userId",
          ".write": "auth != null && auth.uid == $userId"
        },
        "friends": {
          ".read": "auth != null",
          ".write": "auth != null"
        },
        "status": {
          ".read": "auth != null",
          ".write": "auth != null && auth.uid == $userId"
        }
      }
    },
    "projects": {
      "$projectId": {
        ".read": true,
        ".write": true,
        "metadata": {
          ".read": true,
          ".write": true
        },
        "members": {
          ".read": true,
          ".write": true
        },
        "collaborators": {
          ".read": true,
          ".write": true
        }
      }
    },
    "documents": {
      "$documentId": {
        ".read": true,
        ".write": true,
        "users": {
          ".read": true,
          ".write": true
        },
        "content": {
          ".read": true,
          ".write": true
        },
        "chat": {
          ".read": true,
          ".write": true
        },
        "cursors": {
          ".read": true,
          ".write": true
        },
        "files": {
          ".read": true,
          ".write": true
        }
      }
    },
    "conversations": {
      "$conversationId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "messages": {
          ".read": "auth != null",
          ".write": "auth != null"
        },
        "participants": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    },
    "community": {
      "posts": {
        ".read": true,
        ".write": "auth != null",
        "$postId": {
          ".read": true,
          ".write": "auth != null"
        }
      },
      "following": {
        "$userId": {
          ".read": "auth != null",
          ".write": "auth != null && auth.uid == $userId"
        }
      },
      "followers": {
        "$userId": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    }
  }
}
